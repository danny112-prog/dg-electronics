# ═══════════════════════════════════════════════════════════════
# DG Electronics - Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and replace the placeholder values
# with your actual API keys from Paystack Dashboard.
#
# Get your keys at: https://dashboard.paystack.com/settings/keys
# Webhook secret at: https://dashboard.paystack.com/settings/webhooks
# ═══════════════════════════════════════════════════════════════

# ── Server ──
PORT=3000
JWT_SECRET=your-jwt-secret-here
MONGO_URI=const mongoose = require("mongoose");

mongoose.connect(process.env.MONGODB_URI)
  .then(() => console.log("MongoDB connected"))
  .catch(err => {
    console.error("MongoDB connection error:", err.message);
    process.exit(1);
  });
BASE_URL=http://localhost:3000

# ── Paystack ──
# PUBLIC KEY — Used by frontend to initialize payments
# Found at: Dashboard → Settings → API Keys → Public Key
# Starts with pk_test_ (test) or pk_live_ (live)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SECRET KEY — Used by backend to verify payments (NEVER expose to frontend!)
# Found at: Dashboard → Settings → API Keys → Secret Key
# Starts with sk_test_ (test) or sk_live_ (live)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WEBHOOK SECRET — Used to verify webhook signatures from Paystack
# Found at: Dashboard → Settings → Webhooks → Signing Secret
# Starts with whsec_
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
